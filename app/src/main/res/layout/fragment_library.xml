<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="내 보관함"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="#000000"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylistTabs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#F9F9F9"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tlLibraryBrand"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            app:tabMode="fixed"
            app:tabIndicatorHeight="3dp"
            app:tabSelectedTextColor="#2196F3"
            app:tabIndicatorColor="#2196F3">
            <com.google.android.material.tabs.TabItem android:text="전체" />
            <com.google.android.material.tabs.TabItem android:text="TJ" />
            <com.google.android.material.tabs.TabItem android:text="금영" />
            <com.google.android.material.tabs.TabItem android:text="JOY" />
            <com.google.android.material.tabs.TabItem android:text="DAM" />
        </com.google.android.material.tabs.TabLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylistSongs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="100dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:orientation="vertical">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabRename"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="이름변경"
            android:textColor="#FFFFFF"
            app:backgroundTint="#FFB300" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabEditOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="순서편집"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2196F3" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabAddPlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="추가"
            android:textColor="#FFFFFF"
            app:backgroundTint="#4CAF50" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
