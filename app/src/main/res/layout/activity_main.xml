<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_navigation" />

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#1A1A1A"
        android:orientation="horizontal">

        <Button android:id="@+id/btnNavSearch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="검색" android:textColor="#FFFFFF" style="?android:attr/borderlessButtonStyle"/>
        <Button android:id="@+id/btnNavNew" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="신곡" android:textColor="#FFFFFF" style="?android:attr/borderlessButtonStyle"/>
        <Button android:id="@+id/btnNavBookmark" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="보관함" android:textColor="#FFFFFF" style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>
</RelativeLayout>
