<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnTj" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TJ"/>
        <Button android:id="@+id/btnKy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="KY"/>
        <Button android:id="@+id/btnJoy" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="JOY"/>
        <Button android:id="@+id/btnDam" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DAM"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:layout_marginTop="8dp"/>
    <TextView android:id="@+id/tvMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FF0000" android:layout_marginTop="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"/>
</LinearLayout>
